# No key is required: demo is the deterministic default.
LLM_PROVIDER=demo
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
DATABASE_URL=sqlite:///./global_equity_council.db
DATA_PROVIDER=fixture
# Optional BYOK live quote providers:
# DATA_PROVIDER=twelvedata
# MARKET_DATA_API_KEY=your-twelvedata-or-finnhub-key
# TWELVEDATA_API_KEY=your-twelvedata-key
# FINNHUB_API_KEY=your-finnhub-key
MARKET_DATA_CACHE_TTL_SECONDS=900
SEC_USER_AGENT=GlobalEquityCouncil/1.0 contact@example.com
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
VITE_API_BASE=/api
FRONTEND_DIST=/app/frontend-dist
